# Dependencies
node_modules/

# Build output (tsc-owned; never committed)
dist/
*.tsbuildinfo

# LICENSE copied into the package at publish time by its `prepack` script
# (single source of truth stays at the repo root). Generated, never committed.
packages/m3l-common/LICENSE

# Turborepo local cache / logs
.turbo/

# rumdl markdown-lint cache (CI uses --no-cache; this guards manual runs)
.rumdl_cache/

# Test / coverage artifacts
coverage/

# M3LScript run output (timestamped archival dirs)
data/output/*
!data/output/.gitkeep

# Skill eval workspaces (generated artefacts from skill-creator runs)
.claude/skills/*/**-workspace/

# Git worktrees created by `claude --worktree` / isolated spokes (nested checkouts)
.claude/worktrees/

# Logs and OS cruft
*.log
.DS_Store

# Local env / secrets (NPM_TOKEN, GITHUB_TOKEN live in CI vault only)
.env
.env.*
!.env.example

# Claude
.claire/
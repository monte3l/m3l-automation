{
  "name": "@m3l-automation/logs-insights",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Run CloudWatch Logs Insights queries and export results, splitting by time window for the 10k-row cap",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsc -b tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json",
    "start": "node --env-file-if-exists=.env dist/main.js"
  },
  "dependencies": {
    "@m3l-automation/m3l-common": "workspace:*"
  }
}

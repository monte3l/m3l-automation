{
  "name": "@m3l-automation/json-etl",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "JSON and NDJSON file ETL: extract fields, filter records, export to json, jsonl, csv, or html",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsc -b tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json",
    "start": "node --env-file-if-exists=.env dist/main.js"
  },
  "dependencies": {
    "@m3l-automation/m3l-common": "workspace:*"
  }
}

{
  "name": "@m3l-automation/m3l-common",
  "version": "1.1.0",
  "type": "module",
  "description": "Utilities library with enterprise-grade abstractions for automation scripts: configuration, logging, error handling, import/export, polling/retry, and AWS integration.",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=24"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "default": "./dist/core/index.js"
    },
    "./aws": {
      "types": "./dist/aws/index.d.ts",
      "default": "./dist/aws/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -b tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json",
    "prepack": "cp ../../LICENSE ./LICENSE"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/monte3l/m3l-automation.git",
    "directory": "packages/m3l-common"
  },
  "homepage": "https://github.com/monte3l/m3l-automation/tree/main/packages/m3l-common#readme",
  "bugs": "https://github.com/monte3l/m3l-automation/issues",
  "author": "Enrico Lionello",
  "keywords": [
    "automation",
    "cli",
    "aws",
    "typescript",
    "esm",
    "logging",
    "configuration",
    "retry",
    "polling",
    "lambda"
  ],
  "dependencies": {
    "@aws-sdk/client-api-gateway": "3.1079.0",
    "@aws-sdk/client-athena": "3.1079.0",
    "@aws-sdk/client-cloudformation": "3.1079.0",
    "@aws-sdk/client-cloudwatch": "3.1079.0",
    "@aws-sdk/client-cloudwatch-logs": "3.1079.0",
    "@aws-sdk/client-codepipeline": "3.1079.0",
    "@aws-sdk/client-dynamodb": "3.1079.0",
    "@aws-sdk/client-ec2": "3.1079.0",
    "@aws-sdk/client-ecs": "3.1079.0",
    "@aws-sdk/client-eks": "3.1079.0",
    "@aws-sdk/client-eventbridge": "3.1079.0",
    "@aws-sdk/client-lambda": "3.1079.0",
    "@aws-sdk/client-s3": "3.1079.0",
    "@aws-sdk/client-sqs": "3.1079.0",
    "@aws-sdk/client-ssm": "3.1079.0",
    "@aws-sdk/client-sts": "3.1085.0",
    "@aws-sdk/credential-provider-ini": "3.972.60",
    "@aws-sdk/credential-providers": "3.1081.0",
    "@aws-sdk/lib-dynamodb": "3.1085.0",
    "@inquirer/prompts": "8.5.2",
    "@smithy/protocol-http": "5.5.9",
    "@smithy/signature-v4": "5.6.5",
    "better-sqlite3": "12.11.1",
    "csv-parse": "7.0.1",
    "csv-stringify": "6.8.0",
    "string-width": "8.2.1",
    "undici": "8.7.0",
    "yaml": "2.9.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/mailparser": "^3.4.6",
    "adm-zip": "^0.6.0",
    "cheerio": "^1.2.0",
    "mailparser": "^3.9.12",
    "mammoth": "^1.12.0",
    "read-excel-file": "^9.3.2",
    "unpdf": "^1.6.2"
  },
  "peerDependencies": {
    "adm-zip": "^0.6.0",
    "cheerio": "^1.2.0",
    "mailparser": "^3.9.12",
    "mammoth": "^1.12.0",
    "read-excel-file": "^9.3.2",
    "unpdf": "^1.6.2"
  },
  "peerDependenciesMeta": {
    "adm-zip": {
      "optional": true
    },
    "cheerio": {
      "optional": true
    },
    "mailparser": {
      "optional": true
    },
    "mammoth": {
      "optional": true
    },
    "read-excel-file": {
      "optional": true
    },
    "unpdf": {
      "optional": true
    }
  }
}

{
  "name": "@m3l-automation/m3l-common",
  "version": "0.0.0-development",
  "type": "module",
  "description": "Utilities library with enterprise-grade abstractions for automation scripts: configuration, logging, error handling, import/export, polling/retry, and AWS integration.",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=24"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "default": "./dist/core/index.js"
    },
    "./aws": {
      "types": "./dist/aws/index.d.ts",
      "default": "./dist/aws/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -b tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/monte3l/m3l-automation.git",
    "directory": "packages/m3l-common"
  },
  "homepage": "https://github.com/monte3l/m3l-automation/tree/main/packages/m3l-common#readme",
  "bugs": "https://github.com/monte3l/m3l-automation/issues",
  "author": "Enrico Lionello",
  "keywords": [
    "automation",
    "cli",
    "aws",
    "typescript",
    "esm",
    "logging",
    "configuration",
    "retry",
    "polling",
    "lambda"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@inquirer/prompts": "8.5.2",
    "better-sqlite3": "^12.11.1",
    "csv-parse": "7.0.0",
    "csv-stringify": "^6.8.0",
    "undici": "8.5.0",
    "yaml": "2.9.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/better-sqlite3": "^7.6.13",
    "@types/mailparser": "^3.4.6",
    "adm-zip": "^0.5.18",
    "cheerio": "^1.2.0",
    "mailparser": "^3.9.12",
    "mammoth": "^1.12.0",
    "read-excel-file": "^9.2.0",
    "unpdf": "^1.6.2"
  },
  "peerDependencies": {
    "adm-zip": "^0.5.18",
    "cheerio": "^1.2.0",
    "mailparser": "^3.9.12",
    "mammoth": "^1.12.0",
    "read-excel-file": "^9.2.0",
    "unpdf": "^1.6.2"
  },
  "peerDependenciesMeta": {
    "adm-zip": {
      "optional": true
    },
    "cheerio": {
      "optional": true
    },
    "mailparser": {
      "optional": true
    },
    "mammoth": {
      "optional": true
    },
    "read-excel-file": {
      "optional": true
    },
    "unpdf": {
      "optional": true
    }
  }
}

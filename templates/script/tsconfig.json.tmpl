{
  "//": "Tooling project (editor + ESLint typed linting + test type-checking). Includes tests; emits nothing. The build uses tsconfig.build.json.",
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "noEmit": true
  },
  "include": ["src/**/*.ts", "tests/**/*.ts"],
  "exclude": ["dist", "node_modules"]
}

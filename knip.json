{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignore": [".claude/**", "commitlint.config.js"],
  "ignoreDependencies": [
    "@commitlint/config-conventional",
    "@commitlint/types"
  ],
  "workspaces": {
    "packages/m3l-common": {
      "entry": "src/index.ts",
      "project": "src/**/*.ts"
    },
    "scripts/*": {
      "entry": "src/main.ts",
      "project": "src/**/*.ts"
    }
  }
}

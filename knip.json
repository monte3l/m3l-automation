{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignore": [".remember/**", "commitlint.config.js"],
  "ignoreDependencies": [
    "@commitlint/config-conventional",
    "@commitlint/types"
  ],
  "ignoreIssues": {
    "packages/m3l-common/src/core/environment/index.ts": ["duplicates"]
  },
  "workspaces": {
    ".": {
      "entry": [".claude/hooks/**/*.mjs"]
    },
    "packages/m3l-common": {
      "entry": "src/index.ts",
      "project": "src/**/*.ts"
    },
    "scripts/*": {
      "entry": "src/main.ts",
      "project": "src/**/*.ts"
    }
  }
}

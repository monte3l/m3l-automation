{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignore": [".remember/**", "commitlint.config.js"],
  "ignoreDependencies": [
    "@commitlint/config-conventional",
    "@commitlint/types"
  ],
  "ignoreBinaries": ["gh"],
  "ignoreIssues": {
    "packages/m3l-common/src/core/environment/index.ts": ["duplicates"]
  },
  "workspaces": {
    ".": {
      "entry": [
        ".claude/hooks/**/*.mjs",
        ".claude/workflows/**/*.js",
        "bin/mcp-server.mjs"
      ]
    },
    "packages/m3l-common": {
      "entry": "src/index.ts",
      "project": "src/**/*.ts"
    },
    "scripts/*": {
      "entry": "src/main.ts",
      "project": "src/**/*.ts"
    }
  }
}
